# =============================================================================
# ONE SITE = ONE PC = ONE MACHINE
# =============================================================================
# Copy to site.local.yaml on each factory PC (or run 1-CONFIGURE_SITE.cmd).
# Each site gets its OWN site_code, device_id, keys, tunnel hostname, machine IP.
#
# Multi-site example:
#   Site V8  -> outbound_site_code V8  -> device V8-T501-01  -> v8-mw.k95foods.com
#   Site V9  -> outbound_site_code V9  -> device V9-T501-01  -> v9-mw.k95foods.com
#
# After saving: run 2-INSTALL_FACTORY.cmd (Admin), then give DevOps the file:
#   configs/k95-vps-snippet.env
# =============================================================================

# --- 1) Site identity (unique per factory) ---
site_name: "Factory Gate PC 1"
outbound_site_code: "V8"
outbound_device_id: "V8-T501-01"

# --- 2) Biometric machine on LAN (one machine per this PC) ---
machine_sync_ip: "192.168.1.100"
machine_sync_port: 5005
machine_sync_password: 0
machine_sync_machine_number: 1
machine_sdk_dll_path: "sdk_extracted/20211204-SBXPC-1/bin/SBXPCDLL64.dll"
device_lan_ip_for_firewall: ""

# --- Middleware PC LAN IP (auto-set by 3-CONFIGURE_DEVICE.cmd / 4-CONFIGURE_LAN_IP.cmd) ---
# pc_lan_ip: ""                  # empty = lock whatever IP the PC has now; or set e.g. 192.168.29.124
# pc_lan_static_enabled: true     # set false to skip Windows static IP during install

# --- 3) Keys — generate per site (1-CONFIGURE_SITE.cmd auto-fills) ---
# ERP -> this PC (must match K95 VPS MIDDLEWARE_API_KEY for this branch)
middleware_api_key: "change-me-middleware-key"
# This PC -> ERP punches (must match K95 VPS V8_WEBHOOK_SECRET / webhook_secret in branch DB)
outbound_hmac_secret: "change-me-v8-webhook-hmac"

# --- 4) K95 ERP + Cloudflare (usually same ERP URL for all sites) ---
outbound_url: "https://dev.erp.k95foods.com/api/integrations/middleware/punch"
outbound_api_key: ""
cloudflare_public_hostname: "v8-mw.k95foods.com"
cloudflare_tunnel_name: "v8-middleware"
cloudflare_local_port: 8080

# --- Optional (leave defaults unless you use agent/webhook features) ---
agent_api_key: "change-me-agent-key"
webhook_hmac_secret: "change-me-webhook-secret"

# --- Failure alerts (WhatsApp / Telegram / webhook) ---
# Providers: callmebot (WhatsApp), ntfy (phone app), telegram, twilio, webhook
# alerts_enabled: true
# alerts_provider: "callmebot"
# alerts_recipient: "+919876543210"       # phone (callmebot/twilio) or Telegram chat id
# alerts_api_key: "your-callmebot-apikey"  # CallMeBot key / Telegram bot token / Twilio account sid
# alerts_api_secret: ""                    # Twilio auth token only
# alerts_from: "whatsapp:+14155238886"       # Twilio WhatsApp sender only
# alerts_webhook_url: "https://hooks.example.com/alerts"
# alerts_cooldown_seconds: 300
# alerts_events: []                        # empty = all events; or list specific event names
#
# CallMeBot setup: add +34 644 44 96 44 on WhatsApp, send "I allow callmebot to send me messages",
# then set alerts_api_key from https://www.callmebot.com/blog/free-api-whatsapp-messages/
#
# Test: .venv\Scripts\python.exe scripts\test_alerts.py --config configs\factory.yaml
