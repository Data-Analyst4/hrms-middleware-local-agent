# Local dev/test only — runtime uses configs/site.local.yaml on each factory PC.
# Copy to integration.local.env (gitignored).

K95_INTEGRATION_EMAIL=your-hr-admin@company.com
K95_INTEGRATION_PASSWORD=
K95_BASE_URL=https://dev.erp.k95foods.com

# This site's middleware (match site.local.yaml on that PC)
MW_BASE_URL=http://127.0.0.1:8080
MW_API_KEY=same-as-site-local-middleware_api_key
V8_SITE_CODE=V8
V8_DEVICE_ID=V8-T501-01
V8_WEBHOOK_SECRET=same-as-site-local-outbound_hmac_secret

CLOUDFLARE_PUBLIC_HOSTNAME=https://v8-mw.k95foods.com
CLOUDFLARE_LOCAL_PORT=8080
