# K95 ERP backend .env — ONE BLOCK PER SITE/BRANCH on the VPS
# Copy values FROM each factory PC after running 1-CONFIGURE_SITE.cmd
# (also written to configs/k95-vps-snippet.env on that PC — gitignored)

# --- VPS global (set once, never rotate casually) ---
MIDDLEWARE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# --- Site V8 (factory PC 1) ---
MIDDLEWARE_API_KEY=same-as-v8-site-local-middleware_api_key
V8_MIDDLEWARE_API_KEY=same-as-v8-site-local-middleware_api_key
V8_WEBHOOK_SECRET=same-as-v8-site-local-outbound_hmac_secret
V8_TUNNEL_URL=https://v8-mw.k95foods.com
V8_DEVICE_ID=V8-T501-01

# --- Site V9 (factory PC 2) — add another block when you deploy site 2 ---
# V9_MIDDLEWARE_API_KEY=...
# V9_WEBHOOK_SECRET=...
# V9_TUNNEL_URL=https://v9-mw.k95foods.com
# V9_DEVICE_ID=V9-T501-01

# Default URL K95 uses to call middleware (per-site overrides above)
MIDDLEWARE_BASE_URL=https://v8-mw.k95foods.com
